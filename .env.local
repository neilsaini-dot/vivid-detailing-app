# Google OAuth 2.0 — shared credentials for Calendar and Drive
# Set these in Vercel (or your deployment platform) environment variables.
#
# Step 1: Add GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from Google Cloud Console
# Step 2: Visit https://book.vividpei.com/api/auth/google to complete OAuth
# Step 3: Copy the printed refresh token into GOOGLE_REFRESH_TOKEN below

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
