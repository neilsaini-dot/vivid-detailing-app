modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-calendar:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 19466
externalPort = 3000

[userenv]

[userenv.shared]
VITE_BUSINESS_PHONE = "902-267-7775"
VITE_BUSINESS_EMAIL = "contact@vividpei.com"
VITE_BUSINESS_ADDRESS = "2-70 Nicholas Lane, Charlottetown, PE"

[nix]
channel = "stable-25_05"
