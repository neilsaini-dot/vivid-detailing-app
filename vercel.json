{
  "buildCommand": "pnpm install && pnpm --filter @workspace/vivid-detailing run build",
  "outputDirectory": "artifacts/vivid-detailing/dist/public",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  }
}
